@page
@model ErrorModel
@{
    ViewData["Title"] = L["Error_PageTitle"];
}

<h1 class="text-danger">@L["Error_Heading"]</h1>
<h2 class="text-danger">@L["Error_Subheading"]</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>@L["Error_RequestIdLabel"]</strong> <code>@Model.RequestId</code>
    </p>
}

<h3>@L["Error_DevModeTitle"]</h3>
<p>
    @L["Error_DevModeP1"]
</p>
<p>
    @L["Error_DevModeP2"]
</p>
