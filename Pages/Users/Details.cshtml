@page 
@using OnSet.Domain.Enums
@model Users.DetailsModel
@{
    ViewData["Title"] = L["Users_Details_PageTitle"];
}

<div class="container py-5">
    <form method="post" enctype="multipart/form-data">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <div>
                <h1 class="h3 fw-bold mb-0">@L["Users_Details_Heading"]</h1>
                <p class="text-muted">@L["Users_Details_Lead"]</p>
            </div>
            <div class="d-flex gap-2">
                <a asp-page="./Details" asp-route-id="@Model.EditCommand.UserId" class="btn btn-outline-secondary">@L["Common_Cancel"]</a>
                <button type="submit" class="btn btn-primary px-4 shadow-sm">@L["Common_SaveChanges"]</button>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-3 mb-4">
                <div class="card border-0 shadow-sm sticky-top" style="top: 20px;">
                    <div class="list-group list-group-flush" id="edit-tabs" role="tablist">
                        <a class="list-group-item list-group-item-action active p-3" data-bs-toggle="list" href="#basic" role="tab">
                            <i class="bi bi-person me-2"></i>@L["Users_Details_Tab_Basic"]
                        </a>
                        <a class="list-group-item list-group-item-action p-3" data-bs-toggle="list" href="#professional" role="tab">
                            <i class="bi bi-briefcase me-2"></i>@L["Users_Details_Tab_Professional"]
                        </a>
                        <a class="list-group-item list-group-item-action p-3" data-bs-toggle="list" href="#contact" role="tab">
                            <i class="bi bi-geo-alt me-2"></i>@L["Users_Details_Tab_Contact"]
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-lg-9">
                <div class="tab-content">
                    <div class="tab-pane fade show active" id="basic" role="tabpanel">
                        <div class="card border-0 shadow-sm mb-4">
                            <div class="card-body p-4">
                                <h5 class="fw-bold mb-4">@L["Users_Details_Section_Appearance"]</h5>

                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label fw-medium">@L["Users_Details_Label_FirstName"]</label>
                                        <input asp-for="EditCommand.FirstName" class="form-control" placeholder="@L["Users_Details_Placeholder_FirstName"].Value" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-medium">@L["Users_Details_Label_LastName"]</label>
                                        <input asp-for="EditCommand.LastName" class="form-control" placeholder="@L["Users_Details_Placeholder_LastName"].Value" />
                                    </div>
                                    <div class="col-12 mt-4">
                                        <label class="form-label fw-medium">@L["Users_Details_Label_Bio"]</label>
                                        <textarea asp-for="EditCommand.Bio" class="form-control" rows="5" placeholder="@L["Users_Details_Placeholder_Bio"].Value"></textarea>
                                        <div class="form-text">@L["Users_Details_Hint_BioVisibility"]</div>
                                    </div>
                                    <div class="col-12 mt-4">
                                        <label class="form-label fw-medium">@L["Users_Details_Label_ProfileImageUrl"]</label>
                                        <input asp-for="EditCommand.AvatarUrl" class="form-control" placeholder="@L["Users_Details_Placeholder_ProfileImageUrl"].Value" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="professional" role="tabpanel">
                        <div class="card border-0 shadow-sm">
                            <div class="card-body p-4">
                                <h5 class="fw-bold mb-4">@L["Users_Details_Section_WorkAvailability"]</h5>
                                <div class="row g-3">
                                    <div class="col-md-8">
                                        <label asp-for="EditCommand.MainOccupationRole" class="form-label"></label>

                                        <select asp-for="EditCommand.MainOccupationRole"
                                                asp-items="Model.RoleOptions"
                                                class="form-select">
                                            <option value="">@L["Users_Details_SelectRole"]</option>
                                        </select>

                                        <span asp-validation-for="EditCommand.MainOccupationRole" class="text-danger"></span>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label fw-medium">@L["Users_Details_Label_YearsExperience"]</label>
                                        <input asp-for="EditCommand.YearsExperience" type="number" class="form-control" />
                                    </div>

                                    <div class="col-12">
                                        <label asp-for="EditCommand.SpokenLanguages" class="form-label">@L["Users_Details_Label_Languages"]</label>

                                        <select asp-for="EditCommand.SpokenLanguages"
                                                asp-items="Model.LanguageOptions"
                                                class="form-select"
                                                multiple>
                                        </select>

                                        <small class="text-muted">@L["Register_MultiSelectHint"]</small>
                                        <span asp-validation-for="EditCommand.SpokenLanguages" class="text-danger"></span>
                                    </div>

                                    <div class="col-12 py-3">
                                        <div class="form-check form-switch bg-light p-3 rounded border">
                                            <input class="form-check-input ms-0 me-3" type="checkbox" asp-for="EditCommand.IsAvailableForBooking">
                                            <label class="form-check-label fw-bold" asp-for="EditCommand.IsAvailableForBooking">@L["Users_Details_Label_AvailableForBooking"]</label>
                                            <div class="form-text ms-5">@L["Users_Details_Hint_AvailableForBooking"]</div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <label class="form-label fw-medium">@L["Users_Details_Label_NextAvailableDate"]</label>
                                        <input asp-for="EditCommand.NextAvailableDate" type="date" class="form-control" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="contact" role="tabpanel">
                        <div class="card border-0 shadow-sm mb-4">
                            <div class="card-body p-4">
                                <h5 class="fw-bold mb-4">@L["Users_Details_Section_HomeAddress"]</h5>
                                <div class="row g-3">
                                    <div class="col-12">
                                        <label class="form-label small">@L["Projects_Edit_Label_Street"]</label>
                                        <input asp-for="EditCommand.Street" class="form-control" />
                                    </div>
                                    <div class="col-md-5">
                                        <label class="form-label small">@L["Projects_Edit_Label_City"]</label>
                                        <input asp-for="EditCommand.City" class="form-control" />
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label small">@L["Projects_Edit_Label_Province"]</label>
                                        <input asp-for="EditCommand.Province" class="form-control" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label small">@L["Projects_Edit_Label_Zip"]</label>
                                        <input asp-for="EditCommand.ZipCode" class="form-control" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label small">@L["Projects_Edit_Label_Country"]</label>
                                        <input asp-for="EditCommand.Country" class="form-control" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="card border-0 shadow-sm border-start border-danger border-4">
                            <div class="card-body p-4">
                                <h5 class="fw-bold mb-4 text-danger"><i class="bi bi-exclamation-triangle me-2"></i>@L["Register_Section_EmergencyContact"]</h5>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label fw-medium">@L["Users_Details_Label_EmergencyContactName"]</label>
                                        <input asp-for="EditCommand.EmergencyContactName" class="form-control border-danger-subtle" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-medium">@L["Users_Details_Label_EmergencyContactPhone"]</label>
                                        <input asp-for="EditCommand.EmergencyContactPhone" class="form-control border-danger-subtle" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>