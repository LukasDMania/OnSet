@page
@using OnSet.Domain.Enums
@model OnSet.Pages.Users.RegisterModel

@{
    ViewData["Title"] = "Create Account";
}

@{

    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="mb-4 text-center text-lg-start">
                    <h1 class="fw-bold text-dark">@ViewData["Title"]</h1>
                    <p class="text-muted">Join the OnSet community by completing the profile details below.</p>
                </div>

                <form method="post">
                    <div asp-validation-summary="All" class="alert alert-danger shadow-sm border-0 mb-4" role="alert"></div>

                    <div class="row g-4">
                        <div class="col-lg-7">
                            <div class="card border-0 shadow-sm mb-4">
                                <div class="card-body p-4">
                                    <h5 class="fw-bold mb-3"><i class="bi bi-shield-lock me-2 text-primary"></i>Account Credentials</h5>
                                    <div class="row g-3">
                                        <div class="col-12">
                                            <label asp-for="Input.Email" class="form-label fw-medium"></label>
                                            <input asp-for="Input.Email" class="form-control" placeholder="name@example.com" />
                                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                                        </div>
                                        <div class="col-md-6">
                                            <label asp-for="Input.Password" class="form-label fw-medium"></label>
                                            <input asp-for="Input.Password" class="form-control" type="password" />
                                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                                        </div>
                                        <div class="col-md-6">
                                            <label asp-for="Input.ConfirmPassword" class="form-label fw-medium"></label>
                                            <input asp-for="Input.ConfirmPassword" class="form-control" type="password" />
                                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="card border-0 shadow-sm mb-4">
                                <div class="card-body p-4">
                                    <h5 class="fw-bold mb-3"><i class="bi bi-person-badge me-2 text-primary"></i>Professional Profile</h5>
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label asp-for="Input.FirstName" class="form-label fw-medium"></label>
                                            <input asp-for="Input.FirstName" class="form-control" />
                                            <span asp-validation-for="Input.FirstName" class="text-danger small"></span>
                                        </div>
                                        <div class="col-md-6">
                                            <label asp-for="Input.LastName" class="form-label fw-medium"></label>
                                            <input asp-for="Input.LastName" class="form-control" />
                                            <span asp-validation-for="Input.LastName" class="text-danger small"></span>
                                        </div>
                                        <div class="col-md-8">
                                            <label asp-for="Input.MainOccupationRole" class="form-label fw-medium"></label>
                                            <select asp-for="Input.MainOccupationRole" class="form-select" asp-items="Html.GetEnumSelectList<ProjectRoles>()">
                                                <option value="">-- Select Role --</option>
                                            </select>
                                            <span asp-validation-for="Input.MainOccupationRole" class="text-danger small"></span>
                                        </div>
                                        <div class="col-md-4">
                                            <label asp-for="Input.YearsExperience" class="form-label fw-medium"></label>
                                            <input asp-for="Input.YearsExperience" class="form-control" />
                                            <span asp-validation-for="Input.YearsExperience" class="text-danger small"></span>
                                        </div>
                                        <div class="col-12">
                                            <label asp-for="Input.Bio" class="form-label fw-medium"></label>
                                            <textarea asp-for="Input.Bio" class="form-control" rows="3"></textarea>
                                            <span asp-validation-for="Input.Bio" class="text-danger small"></span>
                                        </div>
                                        <div class="col-12">
                                            <label asp-for="Input.AvatarUrl" class="form-label fw-medium"></label>
                                            <input asp-for="Input.AvatarUrl" class="form-control" placeholder="https://..." />
                                            <span asp-validation-for="Input.AvatarUrl" class="text-danger small"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-5">
                            <div class="card border-0 shadow-sm mb-4">
                                <div class="card-body p-4">
                                    <h5 class="fw-bold mb-3"><i class="bi bi-geo-alt me-2 text-primary"></i>Address</h5>
                                    <div class="row g-3">
                                        <div class="col-12">
                                            <label asp-for="Input.Street" class="form-label fw-medium"></label>
                                            <input asp-for="Input.Street" class="form-control" />
                                            <span asp-validation-for="Input.Street" class="text-danger small"></span>
                                        </div>
                                        <div class="col-md-7">
                                            <label asp-for="Input.City" class="form-label fw-medium"></label>
                                            <input asp-for="Input.City" class="form-control" />
                                            <span asp-validation-for="Input.City" class="text-danger small"></span>
                                        </div>
                                        <div class="col-md-5">
                                            <label asp-for="Input.Province" class="form-label fw-medium"></label>
                                            <input asp-for="Input.Province" class="form-control" />
                                            <span asp-validation-for="Input.Province" class="text-danger small"></span>
                                        </div>
                                        <div class="col-md-6">
                                            <label asp-for="Input.ZipCode" class="form-label fw-medium"></label>
                                            <input asp-for="Input.ZipCode" class="form-control" />
                                            <span asp-validation-for="Input.ZipCode" class="text-danger small"></span>
                                        </div>
                                        <div class="col-md-6">
                                            <label asp-for="Input.Country" class="form-label fw-medium"></label>
                                            <input asp-for="Input.Country" class="form-control" />
                                            <span asp-validation-for="Input.Country" class="text-danger small"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="card border-0 shadow-sm mb-4">
                                <div class="card-body p-4">
                                    <h5 class="fw-bold mb-3"><i class="bi bi-calendar-event me-2 text-primary"></i>Availability</h5>
                                    <div class="row g-3">
                                        <div class="col-12">
                                            <label asp-for="Input.SpokenLanguages" class="form-label fw-medium"></label>
                                            <select asp-for="Input.SpokenLanguages" class="form-select" multiple="multiple" asp-items="Html.GetEnumSelectList<Languages>()">
                                            </select>
                                            <div class="form-text small">Hold Ctrl (Cmd) to select multiple.</div>
                                            <span asp-validation-for="Input.SpokenLanguages" class="text-danger small"></span>
                                        </div>
                                        <div class="col-12 py-2">
                                            <div class="form-check form-switch bg-light p-3 rounded border">
                                                <input asp-for="Input.IsAvailableForBooking" class="form-check-input ms-0 me-3" type="checkbox" />
                                                <label asp-for="Input.IsAvailableForBooking" class="form-check-label fw-bold"></label>
                                            </div>
                                        </div>
                                        <div class="col-12">
                                            <label asp-for="Input.NextAvailableDate" class="form-label fw-medium"></label>
                                            <input asp-for="Input.NextAvailableDate" class="form-control" type="date" />
                                            <span asp-validation-for="Input.NextAvailableDate" class="text-danger small"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="card border-0 shadow-sm border-start border-danger border-4">
                                <div class="card-body p-4">
                                    <h5 class="fw-bold mb-3 text-danger"><i class="bi bi-exclamation-triangle me-2"></i>Emergency Contact</h5>
                                    <div class="row g-3">
                                        <div class="col-12">
                                            <label asp-for="Input.EmergencyContactName" class="form-label fw-medium"></label>
                                            <input asp-for="Input.EmergencyContactName" class="form-control" />
                                            <span asp-validation-for="Input.EmergencyContactName" class="text-danger small"></span>
                                        </div>
                                        <div class="col-12">
                                            <label asp-for="Input.EmergencyContactPhone" class="form-label fw-medium"></label>
                                            <input asp-for="Input.EmergencyContactPhone" class="form-control" />
                                            <span asp-validation-for="Input.EmergencyContactPhone" class="text-danger small"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="mt-4">
                                <button type="submit" class="btn btn-primary btn-lg w-100 shadow-sm">
                                    <i class="bi bi-person-plus me-2"></i>Create My Account
                                </button>
                                <p class="text-center text-muted small mt-3">
                                    By registering, you agree to our Terms and Conditions.
                                </p>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
}
