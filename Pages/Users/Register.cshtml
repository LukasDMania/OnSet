@page
@using OnSet.Domain.Enums
@model OnSet.Pages.Users.RegisterModel
@{
    ViewData["Title"] = L["Register_PageTitle"];
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="mb-4 text-center text-lg-start">
                <h1 class="fw-bold text-dark">@ViewData["Title"]</h1>
                <p class="text-muted">@L["Register_Subtitle"]</p>
            </div>

            <form method="post">
                <div asp-validation-summary="All" class="alert alert-danger shadow-sm border-0 mb-4" role="alert"></div>

                <div class="row g-4">
                    <div class="col-lg-7">
                        <div class="card border-0 shadow-sm mb-4">
                            <div class="card-body p-4">
                                <h5 class="fw-bold mb-3"><i class="bi bi-shield-lock me-2 text-primary"></i>@L["Register_Section_AccountCredentials"]</h5>
                                <div class="row g-3">
                                    <div class="col-12">
                                        <label asp-for="Input.AccountType" class="form-label fw-medium"></label>
                                        <select asp-for="Input.AccountType" class="form-select" asp-items="Html.GetEnumSelectList<AccountType>()"></select>
                                        <span asp-validation-for="Input.AccountType" class="text-danger small"></span>
                                    </div>
                                    <div class="col-12">
                                        <label asp-for="Input.Email" class="form-label fw-medium"></label>
                                        <input asp-for="Input.Email" class="form-control" placeholder="@L["Register_Placeholder_Email"].Value" />
                                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="Input.Password" class="form-label fw-medium"></label>
                                        <input asp-for="Input.Password" class="form-control" type="password" />
                                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="Input.ConfirmPassword" class="form-label fw-medium"></label>
                                        <input asp-for="Input.ConfirmPassword" class="form-control" type="password" />
                                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="card border-0 shadow-sm mb-4">
                            <div class="card-body p-4">
                                <h5 class="fw-bold mb-3"><i class="bi bi-person-badge me-2 text-primary"></i>@L["Register_Section_ProfessionalProfile"]</h5>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label asp-for="Input.FirstName" class="form-label fw-medium"></label>
                                        <input asp-for="Input.FirstName" class="form-control" />
                                        <span asp-validation-for="Input.FirstName" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="Input.LastName" class="form-label fw-medium"></label>
                                        <input asp-for="Input.LastName" class="form-control" />
                                        <span asp-validation-for="Input.LastName" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-8">
                                        <label asp-for="Input.MainOccupationRole" class="form-label fw-medium"></label>
                                        <select asp-for="Input.MainOccupationRole" class="form-select" asp-items="Html.GetEnumSelectList<ProjectRoles>()">
                                            <option value="">@L["Register_SelectRole"]</option>
                                        </select>
                                        <span asp-validation-for="Input.MainOccupationRole" class="text-danger small"></span>
                                    </div>
                                    <div class="col-12">
                                        <label asp-for="Input.Bio" class="form-label fw-medium"></label>
                                        <textarea asp-for="Input.Bio" class="form-control" rows="3"></textarea>
                                        <span asp-validation-for="Input.Bio" class="text-danger small"></span>
                                    </div>
                                    <div class="col-12">
                                        <label asp-for="Input.AvatarUrl" class="form-label fw-medium"></label>
                                        <input asp-for="Input.AvatarUrl" class="form-control" placeholder="@L["Register_Placeholder_AvatarUrl"].Value" />
                                        <span asp-validation-for="Input.AvatarUrl" class="text-danger small"></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-5">
                        <div class="card border-0 shadow-sm mb-4">
                            <div class="card-body p-4">
                                <h5 class="fw-bold mb-3"><i class="bi bi-geo-alt me-2 text-primary"></i>@L["Register_Section_Address"]</h5>
                                <div class="row g-3">
                                    <div class="col-12">
                                        <label asp-for="Input.Street" class="form-label fw-medium"></label>
                                        <input asp-for="Input.Street" class="form-control" />
                                        <span asp-validation-for="Input.Street" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-7">
                                        <label asp-for="Input.City" class="form-label fw-medium"></label>
                                        <input asp-for="Input.City" class="form-control" />
                                        <span asp-validation-for="Input.City" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-5">
                                        <label asp-for="Input.Province" class="form-label fw-medium"></label>
                                        <input asp-for="Input.Province" class="form-control" />
                                        <span asp-validation-for="Input.Province" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="Input.ZipCode" class="form-label fw-medium"></label>
                                        <input asp-for="Input.ZipCode" class="form-control" />
                                        <span asp-validation-for="Input.ZipCode" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="Input.Country" class="form-label fw-medium"></label>
                                        <input asp-for="Input.Country" class="form-control" />
                                        <span asp-validation-for="Input.Country" class="text-danger small"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="card border-0 shadow-sm mb-4">
                            <div class="card-body p-4">
                                <h5 class="fw-bold mb-3"><i class="bi bi-calendar-event me-2 text-primary"></i>@L["Register_Section_Availability"]</h5>
                                <div class="row g-3">
                                    <div class="col-12">
                                        <label asp-for="Input.SpokenLanguages" class="form-label fw-medium"></label>
                                        <select asp-for="Input.SpokenLanguages" class="form-select" multiple="multiple" asp-items="Html.GetEnumSelectList<Languages>()">
                                        </select>
                                        <div class="form-text small">@L["Register_MultiSelectHint"]</div>
                                        <span asp-validation-for="Input.SpokenLanguages" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="Input.DateOfBirth" class="form-label fw-medium"></label>
                                        <input asp-for="Input.DateOfBirth" class="form-control" type="date" />
                                        <span asp-validation-for="Input.DateOfBirth" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="Input.PlaceOfBirth" class="form-label fw-medium"></label>
                                        <input asp-for="Input.PlaceOfBirth" class="form-control" />
                                        <span asp-validation-for="Input.PlaceOfBirth" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="Input.Nationality" class="form-label fw-medium"></label>
                                        <input asp-for="Input.Nationality" class="form-control" />
                                        <span asp-validation-for="Input.Nationality" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="Input.NationalRegistrationNumber" class="form-label fw-medium"></label>
                                        <input asp-for="Input.NationalRegistrationNumber" class="form-control" />
                                        <span asp-validation-for="Input.NationalRegistrationNumber" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="Input.MaritalStatus" class="form-label fw-medium"></label>
                                        <select asp-for="Input.MaritalStatus" class="form-select" asp-items="Html.GetEnumSelectList<MaritalStatus>()">
                                            <option value="">@L["Common_NotAvailable"]</option>
                                        </select>
                                        <span asp-validation-for="Input.MaritalStatus" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="Input.DietaryPreference" class="form-label fw-medium"></label>
                                        <select asp-for="Input.DietaryPreference" class="form-select" asp-items="Html.GetEnumSelectList<DietaryPreference>()">
                                            <option value="">@L["Common_NotAvailable"]</option>
                                        </select>
                                        <span asp-validation-for="Input.DietaryPreference" class="text-danger small"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="card border-0 shadow-sm border-start border-danger border-4">
                            <div class="card-body p-4">
                                <h5 class="fw-bold mb-3 text-danger"><i class="bi bi-exclamation-triangle me-2"></i>@L["Register_Section_EmergencyContact"]</h5>
                                <div class="row g-3">
                                    <div class="col-12">
                                        <label asp-for="Input.EmergencyContactName" class="form-label fw-medium"></label>
                                        <input asp-for="Input.EmergencyContactName" class="form-control" />
                                        <span asp-validation-for="Input.EmergencyContactName" class="text-danger small"></span>
                                    </div>
                                    <div class="col-12">
                                        <label asp-for="Input.EmergencyContactPhone" class="form-label fw-medium"></label>
                                        <input asp-for="Input.EmergencyContactPhone" class="form-control" />
                                        <span asp-validation-for="Input.EmergencyContactPhone" class="text-danger small"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mt-4">
                            <button type="submit" class="btn btn-primary btn-lg w-100 shadow-sm">
                                <i class="bi bi-person-plus me-2"></i>@L["Register_Submit"]
                            </button>
                            <p class="text-center text-muted small mt-3">
                                @L["Register_TermsNote"]
                            </p>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
