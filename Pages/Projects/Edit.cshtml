@page "{id:int}"
@using OnSet.Domain.Enums
@model OnSet.Pages.Projects.EditModel
@{
    ViewData["Title"] = "Edit Project | " + Model.Data.Name;
}

<div class="container py-5">
    <form method="post">
        <input type="hidden" asp-for="Data.Id" />

        <div class="d-flex justify-content-between align-items-end mb-4">
            <div>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-2 text-uppercase fw-bold" style="font-size: 0.7rem; letter-spacing: 1px;">
                        <li class="breadcrumb-item"><a href="/Projects" class="text-decoration-none">Projects</a></li>
                        <li class="breadcrumb-item active">Edit Mode</li>
                    </ol>
                </nav>
                <h1 class="display-6 fw-bold mb-0">Edit Project</h1>
            </div>
            <div class="d-flex gap-2">
                <a href="/Projects/Details/@Model.Data.Id" class="btn btn-outline-secondary px-4">Cancel</a>
                <button type="submit" class="btn btn-dark px-4 shadow-sm">
                    <i class="bi bi-cloud-arrow-up me-2"></i>Save Changes
                </button>
            </div>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger border-0 shadow-sm mb-4">
                <div asp-validation-summary="All" class="small"></div>
            </div>
        }

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4 border-bottom pb-2">General Information</h5>
                        <div class="row g-3">
                            <div class="col-12">
                                <label asp-for="Data.Name" class="form-label fw-semibold small text-muted text-uppercase">Project Name</label>
                                <input asp-for="Data.Name" class="form-control form-control-lg border-2" placeholder="Enter project name..." />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Data.ClientName" class="form-label fw-semibold small text-muted text-uppercase">Client Name</label>
                                <input asp-for="Data.ClientName" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Data.ReferenceCode" class="form-label fw-semibold small text-muted text-uppercase">Reference Code</label>
                                <input asp-for="Data.ReferenceCode" class="form-control" />
                            </div>
                            <div class="col-12">
                                <label asp-for="Data.Description" class="form-label fw-semibold small text-muted text-uppercase">Description</label>
                                <textarea asp-for="Data.Description" class="form-control" rows="4" placeholder="Brief project summary..."></textarea>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4 border-bottom pb-2">Logistics & Location</h5>
                        <div class="row g-3">
                            <div class="col-12">
                                <label asp-for="Data.Street" class="form-label fw-semibold small text-muted text-uppercase">Street Address</label>
                                <input asp-for="Data.Street" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Data.City" class="form-label fw-semibold small text-muted text-uppercase">City</label>
                                <input asp-for="Data.City" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Data.Province" class="form-label fw-semibold small text-muted text-uppercase">Province / State</label>
                                <input asp-for="Data.Province" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Data.ZipCode" class="form-label fw-semibold small text-muted text-uppercase">Zip / Postal Code</label>
                                <input asp-for="Data.ZipCode" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Data.Country" class="form-label fw-semibold small text-muted text-uppercase">Country</label>
                                <input asp-for="Data.Country" class="form-control" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card border-0 shadow-sm mb-4 bg-light">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4 border-bottom pb-2">Project Lifecycle</h5>
                        <div class="mb-4">
                            <label asp-for="Data.Status" class="form-label fw-semibold small text-muted text-uppercase">Project Status</label>
                            <select asp-for="Data.Status" asp-items="Html.GetEnumSelectList<ProjectStatus>()" class="form-select border-2 border-primary"></select>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Data.StartDate" class="form-label fw-semibold small text-muted text-uppercase">Start Date</label>
                            <input asp-for="Data.StartDate" type="date" class="form-control" />
                        </div>
                        <div class="mb-0">
                            <label asp-for="Data.EndDate" class="form-label fw-semibold small text-muted text-uppercase">Estimated End Date</label>
                            <input asp-for="Data.EndDate" type="date" class="form-control" />
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm mb-4 bg-dark text-white">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4 border-bottom border-secondary pb-2">Financials</h5>
                        <div class="mb-3">
                            <label asp-for="Data.Budget" class="form-label fw-semibold small text-secondary text-uppercase">Total Budget</label>
                            <div class="input-group">
                                <span class="input-group-text bg-secondary border-0 text-white">$</span>
                                <input asp-for="Data.Budget" class="form-control bg-transparent text-white border-secondary" placeholder="0.00" />
                            </div>
                        </div>
                        <div class="mb-0">
                            <label asp-for="Data.ActualCost" class="form-label fw-semibold small text-secondary text-uppercase">Actual Cost to Date</label>
                            <div class="input-group">
                                <span class="input-group-text bg-secondary border-0 text-white">$</span>
                                <input asp-for="Data.ActualCost" class="form-control bg-transparent text-white border-secondary" placeholder="0.00" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<style>
    body {
        background-color: #f4f7f6;
    }

    .form-control:focus, .form-select:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.1);
    }

    .card {
        border-radius: 12px;
    }
</style>