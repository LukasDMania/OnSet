@page
@model OnSet.Pages.Projects.IndexModel
@{
    ViewData["Title"] = L["Projects_Index_PageTitle"];
}

<div class="container py-5">
    <div class="row mb-4 align-items-center">
        <div class="col-lg-7">
            <h1 class="fw-bold mb-1">@L["Projects_Index_Heading"]</h1>
            <div class="text-muted small">
                @L["Projects_Index_Lead"]
            </div>
        </div>
        @if (Model.IsProductionAccount)
        {
            <div class="col-lg-5 text-lg-end mt-3 mt-lg-0">
                <a asp-page="./Create" class="btn btn-primary shadow-sm me-2">
                    <i class="bi bi-plus-square me-2"></i>@L["Projects_Index_CreateProject"]
                </a>
            </div>
        }
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            @if (Model.Data.Projects.Count == 0)
            {
                <div class="alert alert-dark border-0 shadow-sm d-flex align-items-center">
                    <i class="bi bi-shield-lock me-3"></i>
                    <div>
                        <div class="fw-semibold">@L["Projects_Index_EmptyTitle"]</div>
                        <div class="small text-muted">
                            @L["Projects_Index_EmptyBody"]
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="card border-0 shadow-sm">
                    <div class="card-header border-0 bg-transparent d-flex justify-content-between align-items-center">
                        <span class="small text-uppercase text-muted fw-bold">@L["Projects_Index_TableCaption"]</span>
                        <span class="badge bg-secondary bg-opacity-50">@Model.Data.Projects.Count</span>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>@L["Projects_Index_ColName"]</th>
                                    <th>@L["Projects_Index_ColClient"]</th>
                                    <th>@L["Projects_Index_ColCode"]</th>
                                    <th>@L["Projects_Index_ColStart"]</th>
                                    <th>@L["Projects_Index_ColEnd"]</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var p in Model.Data.Projects)
                                {
                                    <tr>
                                        <td class="fw-semibold">@p.Name</td>
                                        <td>@(p.ClientName ?? L["Common_EmDash"].Value)</td>
                                        <td class="text-monospace small">@(p.ReferenceCode ?? L["Common_EmDash"].Value)</td>
                                        <td>@p.StartDate.ToShortDateString()</td>
                                        <td>@(p.EndDate?.ToShortDateString() ?? L["Common_EmDash"].Value)</td>
                                        <td class="text-end">
                                            <a asp-page="/Projects/Project" asp-route-id="@p.Id" class="btn btn-sm btn-outline-light">
                                                @L["Common_View"]
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-2 d-flex align-items-center">
                        <i class="bi bi-key-fill text-warning me-2"></i>
                        @L["Projects_Index_JoinTitle"]
                    </h5>
                    <p class="small text-muted mb-3">
                        @L["Projects_Index_JoinBody"]
                    </p>
                    <form method="post" asp-page-handler="Join">
                        <div class="mb-3">
                            <label class="form-label fw-medium" asp-for="JoinCode">@L["Projects_Index_ProjectCode"]</label>
                            <input class="form-control" asp-for="JoinCode" placeholder="@L["Projects_Index_JoinCodePlaceholder"].Value" />
                        </div>
                        <div asp-validation-summary="All" class="text-warning small mb-2"></div>
                        <button type="submit" class="btn btn-warning w-100">
                            <i class="bi bi-box-arrow-in-right me-1"></i>@L["Projects_Index_JoinProject"]
                        </button>
                    </form>
                </div>
            </div>

            <div class="small text-muted">
                @L["Projects_Index_JoinFootnote"]
            </div>
        </div>
    </div>
</div>
