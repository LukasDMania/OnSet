@page "/Projects/{Id:int}"
@using OnSet.Domain.Enums
@model OnSet.Pages.Projects.ProjectModel
@{
    ViewData["Title"] = string.Format(L["Projects_Project_BrowserTitle"].Value, Model.Data.Name);
}

<div class="container py-5">
    <div class="project-header p-4 mb-5 rounded-4 shadow-sm border bg-white">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-2 text-uppercase fw-bold" style="font-size: 0.7rem; letter-spacing: 1px;">
                        <li class="breadcrumb-item"><a asp-page="/Projects/Index" class="text-decoration-none">@L["Projects_Breadcrumb_Portfolio"]</a></li>
                        <li class="breadcrumb-item active text-primary">@Model.Data.ReferenceCode</li>
                    </ol>
                </nav>
                <div class="d-flex align-items-center gap-3 flex-wrap">
                    <h1 class="display-6 fw-bold mb-0 text-dark">@Model.Data.Name</h1>
                </div>
                <p class="text-muted mt-3 mb-0 d-flex align-items-center gap-4">
                    <span><i class="bi bi-person-badge me-2"></i><strong>@L["Projects_Project_Client"]</strong> @(Model.Data.ClientName ?? L["Projects_Project_InternalProduction"].Value)</span>
                    <span><i class="bi bi-hash me-2"></i><strong>@L["Projects_Details_Ref"]</strong> @(Model.Data.ReferenceCode ?? L["Common_NotAvailable"].Value)</span>
                </p>
            </div>
            <div class="col-lg-4 text-lg-end mt-4 mt-lg-0">
                <div class="btn-group shadow-sm">
                    <a asp-page="/Projects/Details" asp-route-id="@Model.Data.Id" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-card-text me-2"></i>@L["Projects_Project_Details"]
                    </a>
                    <a asp-page="/Projects/Edit" asp-route-id="@Model.Data.Id" class="btn btn-outline-dark px-4">
                        <i class="bi bi-pencil-square me-2"></i>@L["Projects_Project_Edit"]
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="fw-bold mb-1">@L["Projects_Project_DocumentsTitle"]</h5>
                        <p class="small text-muted mb-0">
                            @L["Projects_Project_DocumentsLead"]
                        </p>
                    </div>
                    <div class="text-end">
                        @if (Model.Data.CanUploadDocuments)
                        {
                            <form method="post"
                                  asp-page-handler="Upload"
                                  asp-route-id="@Model.Data.Id"
                                  enctype="multipart/form-data"
                                  class="text-start">
                                <div class="row g-2 align-items-end">
                                    <div class="col-md-4">
                                        <label class="form-label small fw-semibold" asp-for="Upload.Tag">@L["Projects_Project_DocumentType"]</label>
                                        <select class="form-select form-select-sm" asp-for="Upload.Tag">
                                            @foreach (DocumentTags tag in Enum.GetValues(typeof(DocumentTags)))
                                            {
                                                <option value="@tag">@tag.ToString().ToLowerInvariant().Replace("_", " ")</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-5">
                                        <label class="form-label small fw-semibold" asp-for="Upload.File">@L["Projects_Project_File"]</label>
                                        <input class="form-control form-control-sm" asp-for="Upload.File" type="file" />
                                    </div>
                                    <div class="col-md-3 text-end">
                                        <button type="submit" class="btn btn-dark btn-sm px-3 mt-2 mt-md-0">
                                            <i class="bi bi-cloud-arrow-up me-1"></i>@L["Projects_Project_Upload"]
                                        </button>
                                    </div>
                                </div>
                                <div class="mt-2">
                                    <label class="form-label small fw-semibold" asp-for="Upload.Description">@L["Projects_Project_NotesOptional"]</label>
                                    <input class="form-control form-control-sm" asp-for="Upload.Description" placeholder="e.g. Call sheet – Day 1" />
                                </div>
                                <div asp-validation-summary="All" class="small text-danger mt-2"></div>
                                <p class="small text-muted mt-1 mb-0">
                                    @L["Projects_Project_UploadNote"]
                                </p>
                            </form>
                        }
                        else
                        {
                            <span class="badge bg-light text-muted border small">
                                @L["Projects_Project_UploadManagedByOffice"]
                            </span>
                        }
                    </div>
                </div>
            </div>

            @if (!Model.Data.DocumentGroups.Any() || Model.Data.DocumentGroups.All(g => !g.Documents.Any()))
            {
                <div class="alert alert-light border-0 shadow-sm d-flex align-items-center">
                    <i class="bi bi-folder-x me-3 text-muted"></i>
                    <div>
                        <div class="fw-semibold">@L["Projects_Project_NoDocumentsTitle"]</div>
                        <div class="small text-muted">
                            @L["Projects_Project_NoDocumentsBody"]
                        </div>
                    </div>
                </div>
            }
            else
            {
                @foreach (var group in Model.Data.DocumentGroups)
                {
                    if (!group.Documents.Any())
                    {
                        continue;
                    }

                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-header border-0 bg-transparent d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-folder2-open text-primary"></i>
                                <span class="small text-uppercase text-muted fw-bold">@group.DisplayName</span>
                            </div>
                            <span class="badge bg-secondary bg-opacity-50">@group.Documents.Count</span>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-hover mb-0 align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>@L["Projects_Project_ColFile"]</th>
                                        <th>@L["Projects_Project_ColUploadedBy"]</th>
                                        <th>@L["Projects_Project_ColUploadedAt"]</th>
                                        <th class="text-end">@L["Projects_Project_ColActions"]</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var doc in group.Documents)
                                    {
                                        <tr>
                                            <td class="fw-semibold">
                                                <i class="bi bi-file-earmark-text me-2 text-muted"></i>
                                                @doc.FileName
                                            </td>
                                            <td>@doc.UploadedBy</td>
                                            <td>@doc.UploadedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                            <td class="text-end">
                                                <a href="@doc.FilePath"
                                                   class="btn btn-sm btn-outline-dark"
                                                   download>
                                                    <i class="bi bi-download me-1"></i>@L["Projects_Project_Download"]
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            }
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4">
                    <h6 class="text-uppercase small fw-bold text-muted mb-3">@L["Projects_Project_QuickLinks"]</h6>
                    <div class="list-group list-group-flush">
                        <a asp-page="/Projects/Details" asp-route-id="@Model.Data.Id"
                           class="list-group-item list-group-item-action border-0 px-0 d-flex justify-content-between align-items-center">
                            <span><i class="bi bi-info-circle me-2 text-primary"></i>@L["Projects_Project_LinkDetails"]</span>
                            <i class="bi bi-chevron-right small text-muted"></i>
                        </a>
                        <a asp-page="/Projects/Edit" asp-route-id="@Model.Data.Id"
                           class="list-group-item list-group-item-action border-0 px-0 d-flex justify-content-between align-items-center">
                            <span><i class="bi bi-pencil-square me-2 text-secondary"></i>@L["Projects_Project_LinkEdit"]</span>
                            <i class="bi bi-chevron-right small text-muted"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f8f9fa;
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
    }

    .project-header {
        border-top: 4px solid #212529;
    }

    .card {
        border-radius: 1rem;
    }

    .breadcrumb-item + .breadcrumb-item::before {
        content: "›";
        color: #adb5bd;
    }
</style>
