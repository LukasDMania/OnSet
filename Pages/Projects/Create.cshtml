@page
@using OnSet.Domain.Enums
@model OnSet.Pages.Projects.CreateModel

@{
    ViewData["Title"] = L["Projects_Create_PageTitle"];
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="mb-4 text-center text-lg-start">
                <h1 class="fw-bold text-dark">@ViewData["Title"]</h1>
                <p class="text-muted">@L["Projects_Create_Lead"]</p>
            </div>

            <form method="post">
                <div asp-validation-summary="All" class="alert alert-danger shadow-sm border-0 mb-4" role="alert"></div>

                <div class="row g-4">
                    <div class="col-lg-7">
                        <div class="card border-0 shadow-sm mb-4">
                            <div class="card-body p-4">
                                <h5 class="fw-bold mb-3"><i class="bi bi-clapperboard me-2 text-primary"></i>@L["Projects_Create_Section_ProjectInformation"]</h5>
                                <div class="row g-3">
                                    <div class="col-12">
                                        <label asp-for="Input.ProjectName" class="form-label fw-medium">@L["Projects_Create_Label_ProjectName"]</label>
                                        <input asp-for="Input.ProjectName" class="form-control" placeholder="@L["Projects_Create_Placeholder_ProjectName"].Value" />
                                        <span asp-validation-for="Input.ProjectName" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="Input.ClientName" class="form-label fw-medium"></label>
                                        <input asp-for="Input.ClientName" class="form-control" />
                                        <span asp-validation-for="Input.ClientName" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="Input.ReferenceCode" class="form-label fw-medium"></label>
                                        <input asp-for="Input.ReferenceCode" class="form-control" placeholder="@L["Projects_Create_Placeholder_ReferenceCode"].Value" />
                                        <span asp-validation-for="Input.ReferenceCode" class="text-danger small"></span>
                                    </div>
                                    <div class="col-12">
                                        <label asp-for="Input.Description" class="form-label fw-medium"></label>
                                        <textarea asp-for="Input.Description" class="form-control" rows="4" placeholder="@L["Projects_Create_Placeholder_Description"].Value"></textarea>
                                        <span asp-validation-for="Input.Description" class="text-danger small"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="card border-0 shadow-sm mb-4">
                            <div class="card-body p-4">
                                <h5 class="fw-bold mb-3"><i class="bi bi-briefcase me-2 text-primary"></i>@L["Projects_Create_Section_Assignment"]</h5>
                                <div class="row g-3">
                                    <div class="col-12">
                                        <label asp-for="Input.CreatorRole" class="form-label fw-medium">@L["Projects_Create_Label_YourRole"]</label>
                                        <select asp-for="Input.CreatorRole" class="form-select" asp-items="Html.GetEnumSelectList<ProjectRoles>()">
                                            <option value="">@L["Projects_Create_SelectYourRole"]</option>
                                        </select>
                                        <span asp-validation-for="Input.CreatorRole" class="text-danger small"></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-5">
                        <div class="card border-0 shadow-sm mb-4">
                            <div class="card-body p-4">
                                <h5 class="fw-bold mb-3"><i class="bi bi-calendar-range me-2 text-primary"></i>@L["Projects_Create_Section_Timeline"]</h5>
                                <div class="row g-3">
                                    <div class="col-12">
                                        <label asp-for="Input.Status" class="form-label fw-medium"></label>
                                        <select asp-for="Input.Status" class="form-select" asp-items="Html.GetEnumSelectList<ProjectStatus>()"></select>
                                        <span asp-validation-for="Input.Status" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="Input.StartDate" class="form-label fw-medium"></label>
                                        <input asp-for="Input.StartDate" class="form-control" type="date" />
                                        <span asp-validation-for="Input.StartDate" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="Input.EndDate" class="form-label fw-medium"></label>
                                        <input asp-for="Input.EndDate" class="form-control" type="date" />
                                        <span asp-validation-for="Input.EndDate" class="text-danger small"></span>
                                    </div>
                                    <div class="col-12">
                                        <label asp-for="Input.Budget" class="form-label fw-medium"></label>
                                        <div class="input-group">
                                            <span class="input-group-text">$</span>
                                            <input asp-for="Input.Budget" class="form-control" placeholder="@L["Projects_Create_Placeholder_Budget"].Value" />
                                        </div>
                                        <span asp-validation-for="Input.Budget" class="text-danger small"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="card border-0 shadow-sm mb-4">
                            <div class="card-body p-4">
                                <h5 class="fw-bold mb-3"><i class="bi bi-geo-alt me-2 text-primary"></i>@L["Projects_Create_Section_PrimaryLocation"]</h5>
                                <div class="row g-3">
                                    <div class="col-12">
                                        <label asp-for="Input.Street" class="form-label fw-medium"></label>
                                        <input asp-for="Input.Street" class="form-control" />
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="Input.City" class="form-label fw-medium"></label>
                                        <input asp-for="Input.City" class="form-control" />
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="Input.Province" class="form-label fw-medium"></label>
                                        <input asp-for="Input.Province" class="form-control" />
                                    </div>
                                    <div class="col-md-5">
                                        <label asp-for="Input.ZipCode" class="form-label fw-medium"></label>
                                        <input asp-for="Input.ZipCode" class="form-control" />
                                    </div>
                                    <div class="col-md-7">
                                        <label asp-for="Input.Country" class="form-label fw-medium"></label>
                                        <input asp-for="Input.Country" class="form-control" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mt-4">
                            <button type="submit" class="btn btn-primary btn-lg w-100 shadow-sm">
                                <i class="bi bi-plus-square me-2"></i>@L["Projects_Create_Submit"]
                            </button>
                            <a asp-page="/Projects/Index" class="btn btn-link w-100 text-muted mt-2">@L["Common_Cancel"]</a>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
