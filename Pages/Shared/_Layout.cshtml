@{
    var returnPath = (Context.Request.Path + Context.Request.QueryString).ToString();
    var useLandingLayout = ViewData["UseLandingLayout"] as bool? == true;
}
<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.TwoLetterISOLanguageName" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - OnSet</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @if (useLandingLayout)
    {
        <link rel="stylesheet" href="~/css/landing.css" asp-append-version="true" />
    }
    <link rel="stylesheet" href="~/OnSet.styles.css" asp-append-version="true" />
</head>
<body class="@(useLandingLayout ? "landing-page" : "")">
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm border-bottom shadow-sm mb-3">
            <div class="container">
                <a class="navbar-brand fw-bold d-flex align-items-center gap-2" asp-area="" asp-page="/Index">
                    <span class="badge bg-primary rounded-circle" style="width: 10px; height: 10px;"></span>
                    <span>OnSet</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label='@L["Layout_NavToggle"]'>
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav me-auto mb-2 mb-sm-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Index">@L["Layout_Nav_Dashboard"]</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-page="/Projects/Index">@L["Layout_Nav_Projects"]</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-page="/Users/Details">@L["Layout_Nav_MyProfile"]</a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav ms-auto mb-2 mb-sm-0 align-items-sm-center">
                        <li class="nav-item dropdown me-sm-2">
                            <a class="nav-link dropdown-toggle" href="#" id="navbarLanguage" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                @L["Layout_Nav_Language"]
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarLanguage">
                                <li>
                                    <a class="dropdown-item" asp-page="/SetLanguage" asp-route-culture="en" asp-route-returnUrl="@returnPath">@L["Layout_Footer_LanguageEnglish"]</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-page="/SetLanguage" asp-route-culture="nl" asp-route-returnUrl="@returnPath">@L["Layout_Footer_LanguageDutch"]</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-page="/SetLanguage" asp-route-culture="fr" asp-route-returnUrl="@returnPath">@L["Layout_Footer_LanguageFrench"]</a>
                                </li>
                            </ul>
                        </li>
                        <li class="nav-item me-2 d-flex align-items-center">
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <span class="small text-muted me-2">@L["Layout_Nav_SignedInAs"]</span>
                                <span class="badge bg-secondary bg-opacity-75">@User.Identity!.Name</span>
                            }
                        </li>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <form asp-page="/Users/Logout" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-light ms-2">@L["Layout_Nav_Logout"]</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-sm btn-outline-light me-2" asp-area="" asp-page="/Users/Login">@L["Layout_Nav_LogIn"]</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-sm btn-primary" asp-area="" asp-page="/Users/Register">@L["Layout_Nav_SignUp"]</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    @if (useLandingLayout)
    {
        <main role="main" class="landing-main">
            @RenderBody()
        </main>
    }
    else
    {
        <div class="container">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
    }

    <footer class="border-top footer text-muted mt-auto">
        <div class="container py-3 small d-flex flex-wrap justify-content-between align-items-center gap-2">
            <span>@L["Layout_Footer_Copyright", DateTime.UtcNow.Year]</span>
            <div class="d-flex align-items-center gap-3">
                <a asp-area="" asp-page="/Privacy" class="link-secondary text-decoration-none">@L["Layout_Footer_Privacy"]</a>
                <span class="text-muted">|</span>
                <a class="link-secondary text-decoration-none" asp-page="/SetLanguage" asp-route-culture="en" asp-route-returnUrl="@returnPath">@L["Layout_Footer_LanguageEnglish"]</a>
                <a class="link-secondary text-decoration-none" asp-page="/SetLanguage" asp-route-culture="nl" asp-route-returnUrl="@returnPath">@L["Layout_Footer_LanguageDutch"]</a>
                <a class="link-secondary text-decoration-none" asp-page="/SetLanguage" asp-route-culture="fr" asp-route-returnUrl="@returnPath">@L["Layout_Footer_LanguageFrench"]</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
