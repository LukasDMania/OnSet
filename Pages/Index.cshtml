@page
@model OnSet.Pages.IndexModel
@{
    ViewData["Title"] = Model.IsAuthenticated ? L["Index_PageTitle"] : L["Index_Landing_PageTitle"];
}

@if (Model.IsAuthenticated)
{
    <partial name="_IndexDashboard" model="Model" />
}
else
{
    <partial name="_IndexLanding" />
}

@section Scripts {
    @if (!Model.IsAuthenticated)
    {
        <script src="~/js/landing.js" asp-append-version="true"></script>
    }
}
