@page
@model OnSet.Pages.IndexModel
@{
    ViewData["Title"] = L["Index_PageTitle"];
}

<div class="container py-5">
    <div class="row justify-content-center mb-5">
        <div class="col-lg-8 text-center">
            <h1 class="display-5 fw-bold mb-3">@L["Index_HeroTitle"]</h1>
            <p class="lead text-muted">
                @L["Index_HeroLead"]
            </p>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-2"><i class="bi bi-person me-2 text-primary"></i>@L["Index_Card_AccountTitle"]</h5>
                    <p class="text-muted small mb-3">
                        @L["Index_Card_AccountBody"]
                    </p>
                    <div class="d-grid gap-2">
                        <a asp-page="/Users/Register" class="btn btn-primary btn-sm">@L["Index_Card_Account_Create"]</a>
                        <a asp-page="/Users/Login" class="btn btn-outline-primary btn-sm">@L["Index_Card_Account_LogIn"]</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-2"><i class="bi bi-briefcase me-2 text-success"></i>@L["Index_Card_ProjectsTitle"]</h5>
                    <p class="text-muted small mb-3">
                        @L["Index_Card_ProjectsBody"]
                    </p>
                    <div class="d-grid gap-2">
                        <a asp-page="/Projects/Index" class="btn btn-success btn-sm">@L["Index_Card_Projects_ViewAll"]</a>
                        <a asp-page="/Projects/Create" class="btn btn-outline-success btn-sm">@L["Index_Card_Projects_Create"]</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-2"><i class="bi bi-person-badge me-2 text-dark"></i>@L["Index_Card_ProfileTitle"]</h5>
                    <p class="text-muted small mb-3">
                        @L["Index_Card_ProfileBody"]
                    </p>
                    <div class="d-grid gap-2">
                        <a asp-page="/Users/Details" class="btn btn-dark btn-sm">@L["Index_Card_Profile_Go"]</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
